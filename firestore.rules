rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // COLLECTION: users
    // ============================================================
    match /users/{userId} {
      // Ai cũng có thể đọc danh sách users (cần cho Admin)
      allow read: if true;

      // User chỉ được tạo/sửa profile của chính mình
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'status', 'createdAt']);

      allow update: if request.auth != null
        && request.auth.uid == userId
        // Không cho user tự thay đổi role
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
            || request.auth.token.email == 'jacksaybin@gmail.com');

      // Xóa: chỉ chính user hoặc admin mới được vô hiệu hóa (soft delete)
      // Hard delete chỉ qua Firebase Admin SDK hoặc Cloud Functions
      allow delete: if false;
    }

    // ============================================================
    // COLLECTION: refundRequests
    // ============================================================
    match /refundRequests/{requestId} {
      // User chỉ đọc yêu cầu của chính mình
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isAdmin());

      // User tạo yêu cầu mới (chỉ status = pending)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
          'userId', 'userEmail', 'bankName', 'accountNumber',
          'accountHolder', 'amount', 'orderCode', 'status',
          'createdAt', 'updatedAt'
        ]);

      // User có thể cập nhật yêu cầu của mình khi đang ở trạng thái pending
      // (để có thể chỉnh sửa hoặc hủy)
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && resource.data.status == 'pending';

      // Admin có thể cập nhật mọi trạng thái
      allow update: if isAdmin();

      // Không ai được xóa yêu cầu
      allow delete: if false;
    }

    // ============================================================
    // COLLECTION: basedata
    // Chứa dữ liệu vé máy bay mẫu - chỉ admin tạo/sửa
    // ============================================================
    match /basedata/{orderId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ============================================================
    // COLLECTION: adminAuditLog
    // Nhật ký hành động admin - chỉ admin đọc, hệ thống ghi
    // ============================================================
    match /adminAuditLog/{logId} {
      allow read: if isAdmin();
      // Tạo log: cho phép nếu là admin
      // (thực tế nên ghi qua Cloud Function để tránh client giả mạo)
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'jacksaybin@gmail.com';
    }
  }
}
